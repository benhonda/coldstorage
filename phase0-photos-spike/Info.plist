<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Embedded into the Mach-O __TEXT,__info_plist section so a CLI/daemon has a TCC identity. -->
  <key>CFBundleIdentifier</key>
  <string>com.coldstorage.photos-spike</string>
  <key>CFBundleName</key>
  <string>ColdStorage Photos Spike</string>
  <!-- REQUIRED: the string the TCC prompt shows. No usage description = no prompt = no access. -->
  <key>NSPhotoLibraryUsageDescription</key>
  <string>ColdStorage reads your photo originals so it can archive them to your private offsite copy.</string>
</dict>
</plist>
