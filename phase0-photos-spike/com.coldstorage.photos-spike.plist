<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- LaunchAgent (per-user, runs in the GUI session — required for Photos/TCC). NOT a LaunchDaemon. -->
  <key>Label</key>
  <string>com.coldstorage.photos-spike</string>
  <key>ProgramArguments</key>
  <array>
    <!-- EDIT to the absolute path of your signed binary, e.g. /Users/you/.../.build/release/photos-spike -->
    <string>/ABSOLUTE/PATH/TO/.build/release/photos-spike</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <!-- launchd defaults cwd to "/"; give it a writable dir so the spike's relative output lands here.
       (The real coldstored plist sets WorkingDirectory to its data dir for the same reason.) -->
  <key>WorkingDirectory</key>
  <string>/tmp</string>
  <key>StandardOutPath</key>
  <string>/tmp/photos-spike.out</string>
  <key>StandardErrorPath</key>
  <string>/tmp/photos-spike.err</string>
</dict>
</plist>
